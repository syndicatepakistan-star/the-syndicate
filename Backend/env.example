# Railway backend env template (copy to Backend/.env for local, set same keys in Railway service variables).
# For production on Railway, configure these in Railway Variables (not committed .env).

# --- Core ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=your-backend.up.railway.app
ALLOWED_HOSTS=your-backend.up.railway.app
RAILWAY_PUBLIC_DOMAIN=your-backend.up.railway.app
DJANGO_SUPERUSER_EMAIL=admin@yourdomain.com
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=change-me-admin-password

# --- PostgreSQL (Railway Postgres plugin usually injects DATABASE_URL automatically) ---
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_SSL_REQUIRE=true

# --- CORS / CSRF (frontend URL) ---
CORS_ALLOWED_ORIGINS=https://your-frontend.up.railway.app
CSRF_TRUSTED_ORIGINS=https://your-frontend.up.railway.app,https://your-backend.up.railway.app

# --- Public URLs ---
FRONTEND_BASE_URL=https://your-frontend.up.railway.app
POST_LOGIN_REDIRECT_URL=https://your-frontend.up.railway.app/dashboard

# --- OpenAI ---
OPENAI_API_KEY=your-openai-key
OPENAI_MODEL=gpt-4o-mini

# --- Email / OTP ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=465
EMAIL_USE_SSL=true
EMAIL_USE_TLS=false
EMAIL_HOST_USER=no-reply@yourdomain.com
EMAIL_HOST_PASSWORD=your-smtp-password
EMAIL_TIMEOUT=15
# Railway fix for SMTP network unreachable in some regions: force IPv4 DNS resolution.
EMAIL_FORCE_IPV4=true
# Optional comma-separated fallback SMTP hosts + ports. Backend tries primary first, then
# fallback hosts using common SMTP combos (465 SSL, 587 TLS).
# Example: EMAIL_FALLBACK_HOSTS=smtp.titan.email,smtp-relay.brevo.com
EMAIL_FALLBACK_HOSTS=
EMAIL_FALLBACK_PORTS=465,587
DEFAULT_FROM_EMAIL=no-reply@yourdomain.com
OTP_EXPIRES_MINUTES=10
# Optional: use Resend HTTPS API for OTP email on Railway (recommended when SMTP egress is blocked).
# If RESEND_API_KEY is set, OTP mailer uses Resend; otherwise it falls back to SMTP settings above.
RESEND_API_KEY=
RESEND_API_URL=https://api.resend.com/emails

# --- Stripe ---
CHECKOUT_AMOUNT_PENCE=33300
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_CHECKOUT_PAYMENT_METHOD_TYPES=card,link

# --- Object Storage (Railway Bucket / S3-compatible) ---
# Keep USE_S3_OBJECT_STORAGE=true for video/image media.
USE_S3_OBJECT_STORAGE=true

# Railway bucket style:
BUCKET=your-bucket-name
ACCESS_KEY_ID=your-bucket-access-key
SECRET_ACCESS_KEY=your-bucket-secret-key
ENDPOINT=https://storage.railway.app
REGION=us-east-1

# Optional AWS-style equivalents (if you prefer these keys):
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_ACCESS_KEY_ID=your-bucket-access-key
# AWS_SECRET_ACCESS_KEY=your-bucket-secret-key
# AWS_S3_ENDPOINT_URL=https://storage.railway.app
# AWS_S3_REGION_NAME=us-east-1

# Optional signed URL lifetime for private object links
PRESIGNED_URL_EXPIRE_SECONDS=3600
# For fast public/static media URLs (program covers, thumbnails), set false.
# Keep true if your bucket is private and requires presigned media URLs.
MEDIA_SIGNED_URLS=false
# Optional public media base for images/thumbnails only (keeps videos signed/protected via backend stream endpoints).
# Example: https://cdn.yourdomain.com/media  OR  https://storage.railway.app/<bucket>
MEDIA_PUBLIC_BASE_URL=

# --- Video streaming ---
# MP4 playback: signed app URL by default (see STREAM_PLAYBACK_USE_S3_PRESIGNED_GET).
VIDEO_CDN_PUBLIC_BASE_URL=https://your-backend.up.railway.app
STREAM_SIGNING_SECRET=change-me-stream-secret
# Shorter TTL limits how long a copied playback link works (trade-off: player may need a fresh URL).
STREAM_SIGNED_URL_TTL_SECONDS=900
# true = direct S3 presigned GET in the browser (smoothest long playback; URL is shareable until TTL). false = Django proxies bytes (more secure UI, heavier).
# If true, configure your bucket CORS to allow GET from your dashboard origin.
STREAM_PLAYBACK_USE_S3_PRESIGNED_GET=true
# Cache per-user+video playback allow/deny for this many seconds (cuts DB load on each MP4 Range). 0 disables.
STREAM_PLAYBACK_DECISION_CACHE_SECONDS=45
# Bytes read per iteration when proxying private video from S3 (default 4MiB). Tune if buffering is slow.
STREAM_S3_PROXY_READ_CHUNK_BYTES=4194304


# Allow request payloads up to 15GB in Django (admin/API multipart).
DATA_UPLOAD_MAX_MB=15360
# Keep memory-safe upload buffering (files above this threshold stream to temp files on disk).
FILE_UPLOAD_MAX_MEMORY_MB=8
# Allow long-running upload requests on Railway web process (seconds).
GUNICORN_TIMEOUT=1800
# Large videos may exceed default 2h ffmpeg/celery limits; bump to 6h.
FFMPEG_TIMEOUT_SECONDS=21600
CELERY_TASK_SOFT_TIME_LIMIT=21000
CELERY_TASK_TIME_LIMIT=21600

# --- Celery / Redis ---
# Railway Redis plugin recommended for background video jobs
REDIS_URL=redis://default:password@host:port
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_TASK_ALWAYS_EAGER=false

# --- Deployment automation switches ---
# true: auto import stream catalog fixture on deploy/start when file exists.
# WARNING: this can overwrite admin-edited playlist fields (including cover_image).
AUTO_LOAD_STREAM_FIXTURE=false
# true: auto upload Backend/media + Frontend-Dashboard/public assets to bucket on deploy/start.
AUTO_SYNC_BUCKET_ASSETS=true
