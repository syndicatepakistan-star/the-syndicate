# Railway + private Cloudflare R2 env template.
# Copy to Backend/.env for local. Production: set in Railway Variables (see docs/HOSTING_RAILWAY_R2.md).

# --- Core ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=your-backend.up.railway.app
ALLOWED_HOSTS=your-backend.up.railway.app
RAILWAY_PUBLIC_DOMAIN=your-backend.up.railway.app
DJANGO_SUPERUSER_EMAIL=admin@yourdomain.com
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=change-me-admin-password

# --- PostgreSQL (Railway Postgres plugin usually injects DATABASE_URL automatically) ---
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_SSL_REQUIRE=true

# --- CORS / CSRF (frontend URL) ---
CORS_ALLOWED_ORIGINS=https://your-frontend.up.railway.app
CSRF_TRUSTED_ORIGINS=https://your-frontend.up.railway.app,https://your-backend.up.railway.app

# --- Public URLs ---
FRONTEND_BASE_URL=https://your-frontend.up.railway.app
POST_LOGIN_REDIRECT_URL=https://your-frontend.up.railway.app/dashboard

# --- OpenAI ---
OPENAI_API_KEY=your-openai-key
OPENAI_MODEL=gpt-4o-mini

# --- Email / OTP ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=465
EMAIL_USE_SSL=true
EMAIL_USE_TLS=false
EMAIL_HOST_USER=no-reply@yourdomain.com
EMAIL_HOST_PASSWORD=your-smtp-password
EMAIL_TIMEOUT=15
# Railway fix for SMTP network unreachable in some regions: force IPv4 DNS resolution.
EMAIL_FORCE_IPV4=true
# Optional comma-separated fallback SMTP hosts + ports. Backend tries primary first, then
# fallback hosts using common SMTP combos (465 SSL, 587 TLS).
# Example: EMAIL_FALLBACK_HOSTS=smtp.titan.email,smtp-relay.brevo.com
EMAIL_FALLBACK_HOSTS=
EMAIL_FALLBACK_PORTS=465,587
DEFAULT_FROM_EMAIL=no-reply@yourdomain.com
OTP_EXPIRES_MINUTES=10
# Optional: use Resend HTTPS API for OTP email on Railway (recommended when SMTP egress is blocked).
# If RESEND_API_KEY is set, OTP mailer uses Resend; otherwise it falls back to SMTP settings above.
RESEND_API_KEY=
RESEND_API_URL=https://api.resend.com/emails

# --- Stripe ---
CHECKOUT_AMOUNT_PENCE=33300
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_CHECKOUT_PAYMENT_METHOD_TYPES=card,link

# --- Object Storage: Cloudflare R2 (private videos) — recommended for Railway production ---
# Create an R2 bucket with public access OFF. API token: Object Read & Write on that bucket.
# S3 API endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com (Cloudflare dashboard → R2 → Overview).
USE_S3_OBJECT_STORAGE=true

AWS_STORAGE_BUCKET_NAME=syndicate-videos
AWS_ACCESS_KEY_ID=your-r2-access-key-id
AWS_SECRET_ACCESS_KEY=your-r2-secret-access-key
AWS_S3_ENDPOINT_URL=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
AWS_S3_REGION_NAME=auto

# Alias keys (same values; settings accepts either style):
# BUCKET=syndicate-videos
# ACCESS_KEY_ID=your-r2-access-key-id
# SECRET_ACCESS_KEY=your-r2-secret-access-key
# ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
# REGION=auto

# Optional signed URL lifetime for private object links
PRESIGNED_URL_EXPIRE_SECONDS=3600
# Signed URLs for private video files on S3 (playback still goes through /api/streaming/...).
# Images use Cloudinary CDN URLs when CLOUDINARY_* is configured (no MEDIA_PUBLIC_BASE_URL needed).
MEDIA_SIGNED_URLS=true
# Optional: public base for legacy S3-hosted images only (skip if using Cloudinary).
# Example: https://cdn.yourdomain.com/media  OR  https://storage.railway.app/<bucket>
MEDIA_PUBLIC_BASE_URL=

# --- Cloudinary (public images: thumbnails, playlist/course covers) ---
# Set CLOUDINARY_URL or all three of CLOUD_NAME / API_KEY / API_SECRET.
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# --- Video streaming (private R2; playback via Django API) ---
# Base URL users hit for stream APIs (your Railway backend domain).
VIDEO_CDN_PUBLIC_BASE_URL=https://your-backend.up.railway.app
STREAM_SIGNING_SECRET=change-me-stream-secret
STREAM_SIGNED_URL_TTL_SECONDS=900
# false = Django proxies MP4 from private R2 (recommended; hides bucket host, no R2 CORS needed).
# true = browser loads short-lived presigned R2 URL (smoother seeks; configure R2 CORS for your frontend origin).
STREAM_PLAYBACK_USE_S3_PRESIGNED_GET=false
# Cache per-user+video playback allow/deny for this many seconds (cuts DB load on each MP4 Range). 0 disables.
STREAM_PLAYBACK_DECISION_CACHE_SECONDS=45  
# Bytes read per iteration when proxying private video from S3 (default 4MiB). Tune if buffering is slow.
STREAM_S3_PROXY_READ_CHUNK_BYTES=4194304


# Allow request payloads up to 15GB in Django (admin/API multipart).
DATA_UPLOAD_MAX_MB=15360
# Keep memory-safe upload buffering (files above this threshold stream to temp files on disk).
FILE_UPLOAD_MAX_MEMORY_MB=8
# Allow long-running upload requests on Railway web process (seconds).
GUNICORN_TIMEOUT=1800
# Large videos may exceed default 2h ffmpeg/celery limits; bump to 6h.
FFMPEG_TIMEOUT_SECONDS=21600
CELERY_TASK_SOFT_TIME_LIMIT=21000
CELERY_TASK_TIME_LIMIT=21600

# --- Redis (optional but recommended on Railway) ---
# Used for membership article search cache. Video MP4 playback does NOT require Redis in the current app.
# Add Railway Redis plugin and paste REDIS_URL here. Skip if you do not use membership search yet.
REDIS_URL=redis://default:password@host:port
# Celery worker is optional (no HLS transcode tasks shipped in this repo). Leave eager off if you add tasks later.
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_TASK_ALWAYS_EAGER=false

# --- Deployment automation switches (Railway git push) ---
# true: on each deploy, run load_stream_playlists if DB has zero playlists (default in nixpacks.toml).
# Safe: skips when playlists already exist. Set false in Railway UI after first deploy if you prefer.
AUTO_LOAD_STREAM_FIXTURE=true
# true: auto upload Backend/media + Frontend-Dashboard/public assets to bucket on deploy/start.
# First deploy only: sync local media/assets to R2, then set false.
AUTO_SYNC_BUCKET_ASSETS=false
