# Frontend Railway env template (copy to Frontend-Dashboard/.env.local for local testing).

# Keep auth enabled in production.
NEXT_PUBLIC_AUTH_REQUIRED=true

# Django backend public URL
NEXT_PUBLIC_SYNDICATE_API_URL=https://your-backend.up.railway.app/api
NEXT_PUBLIC_API_BASE_URL=https://your-backend.up.railway.app

# Next server-side proxy target (same backend)
BACKEND_INTERNAL_URL=https://your-backend.up.railway.app

# Recommended: ensures /static/admin/* is proxied correctly when viewed on frontend host
SYNDICATE_DJANGO_ORIGIN=https://your-backend.up.railway.app

# Post-login target used in OTP flows
NEXT_PUBLIC_POST_LOGIN_REDIRECT_URL=https://your-frontend.up.railway.app/dashboard

# Public site URL for certificate QR codes (e.g. https://your-frontend.up.railway.app)
NEXT_PUBLIC_SITE_URL=https://your-frontend.up.railway.app

# Optional affiliate API override (if using separate service)
# NEXT_PUBLIC_AFFILIATE_API_BASE_URL=https://your-backend.up.railway.app

# Optional demo credentials for login hints (remove in production if not needed)
# NEXT_PUBLIC_DEMO_USERNAME=demo
# NEXT_PUBLIC_DEMO_PASSWORD=change-me
